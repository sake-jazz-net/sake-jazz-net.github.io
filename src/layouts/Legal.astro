---
import Base from "./Base.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
  <header class="legal-header">
    <div class="container">
      <a href="/" class="back-link">&larr; SAKE-JAZZ</a>
    </div>
  </header>
  <main class="legal-main">
    <div class="container">
      <h1>{title}</h1>
      <div class="legal-body">
        <slot />
      </div>
    </div>
  </main>
</Base>

<style>
  .legal-header {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .legal-main {
    padding: 3rem 0 5rem;
  }

  .legal-main h1 {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    color: var(--color-accent);
  }

  .legal-body {
    max-width: 720px;
    font-size: 0.88rem;
    line-height: 1.9;
    color: var(--color-text-muted);
  }

  .legal-body :global(h2) {
    font-size: 1rem;
    color: var(--color-text);
    margin: 2rem 0 0.5rem;
  }

  .legal-body :global(p) {
    margin-bottom: 1rem;
  }

  .legal-body :global(a) {
    word-break: break-all;
  }
</style>
