---
import TicketSelector from "./TicketSelector.astro";

interface TicketEntry {
  label: string;
  amount: number;
  stripePriceId?: string;
  paymentUrl?: string;
  capacity?: number;
}

interface Props {
  title: string;
  date: Date;
  endTime?: string;
  location: string;
  address?: string;
  access?: string;
  mapUrl?: string;
  tickets?: TicketEntry[];
  price: number;
  capacity?: number;
  stripeUrl?: string;
  formUrl?: string;
  organizer?: string;
  sponsor?: string;
  description?: string;
}

const {
  title,
  date,
  endTime,
  location,
  address,
  access,
  mapUrl,
  tickets,
  price,
  capacity,
  stripeUrl,
  formUrl,
  organizer,
  sponsor,
  description,
} = Astro.props;

const formatter = new Intl.DateTimeFormat("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
  weekday: "short",
});

const timeFormatter = new Intl.DateTimeFormat("ja-JP", {
  hour: "2-digit",
  minute: "2-digit",
});

const formattedDate = formatter.format(date);
const formattedTime = timeFormatter.format(date);
const timeRange = endTime ? `${formattedTime}〜${endTime}` : formattedTime;
const isPast = date < new Date();

const ticketUrl = stripeUrl || formUrl;
const ticketLabel = stripeUrl ? "チケットを購入" : "参加申し込み";
---

<article class:list={["event-card", { "is-past": isPast }]}>
  <div class="event-date-badge">
    <span class="event-month"
      >{date.toLocaleDateString("ja-JP", { month: "short" })}</span
    >
    <span class="event-day">{date.getDate()}</span>
  </div>

  <div class="event-body">
    <h3 class="event-title">{title}</h3>

    {description && <p class="event-desc">{description}</p>}

    <dl class="event-details">
      <div class="detail-row">
        <dt>日時</dt>
        <dd>{formattedDate} {timeRange}</dd>
      </div>
      <div class="detail-row">
        <dt>会場</dt>
        <dd>
          {location}
          {
            mapUrl && (
              <a
                href={mapUrl}
                class="map-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
                地図を見る
              </a>
            )
          }
          {address && <span class="sub-text">{address}</span>}
        </dd>
      </div>
      {
        access && (
          <div class="detail-row">
            <dt>アクセス</dt>
            <dd class="sub-text">{access}</dd>
          </div>
        )
      }
      <div class="detail-row">
        <dt>料金</dt>
        <dd>
          {
            tickets && tickets.length > 0 ? (
              <ul class="price-list">
                {tickets.map((t) => (
                  <li>
                    {t.label}：¥{t.amount.toLocaleString("ja-JP")}
                  </li>
                ))}
              </ul>
            ) : (
              <span>¥{price.toLocaleString("ja-JP")}</span>
            )
          }
        </dd>
      </div>
      {
        capacity && (
          <div class="detail-row">
            <dt>定員</dt>
            <dd>{capacity}名</dd>
          </div>
        )
      }
      {
        organizer && (
          <div class="detail-row">
            <dt>主催</dt>
            <dd>{organizer}</dd>
          </div>
        )
      }
      {
        sponsor && (
          <div class="detail-row">
            <dt>協賛</dt>
            <dd>{sponsor}</dd>
          </div>
        )
      }
    </dl>

    <div class="event-actions">
      {
        tickets && tickets.some((t) => t.paymentUrl) && !isPast ? (
          <TicketSelector tickets={tickets} eventTitle={title} />
        ) : ticketUrl && !isPast ? (
          <a
            href={ticketUrl}
            class="ticket-btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            {ticketLabel}
          </a>
        ) : isPast ? (
          <span class="ticket-closed">終了しました</span>
        ) : (
          <span class="ticket-closed">詳細は近日公開</span>
        )
      }
    </div>
  </div>
</article>

<style>
  .event-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    gap: 1.5rem;
    box-shadow: var(--shadow-sm);
    transition:
      border-color 0.3s,
      box-shadow 0.3s;
  }

  .event-card:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
  }

  .event-card.is-past {
    opacity: 0.5;
  }

  .event-card.is-past:hover {
    border-color: var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .event-date-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 3.5rem;
    padding: 0.5rem;
    border-radius: var(--radius);
    background: var(--color-navy);
    color: #fff;
    line-height: 1.2;
    flex-shrink: 0;
    align-self: flex-start;
  }

  .event-month {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }

  .event-day {
    font-size: 1.6rem;
    font-weight: 700;
    font-family: var(--font-serif);
  }

  .event-body {
    flex: 1;
    min-width: 0;
  }

  .event-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
    color: var(--color-text);
    font-family: var(--font-sans);
  }

  .event-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.2rem;
    line-height: 1.8;
    white-space: pre-line;
  }

  .event-details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.2rem;
    font-size: 0.85rem;
  }

  .detail-row {
    display: flex;
    gap: 0.8rem;
  }

  .detail-row dt {
    color: var(--color-text-muted);
    min-width: 4.5rem;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .detail-row dd {
    color: var(--color-text-muted);
  }

  .map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    margin-left: 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-navy);
    white-space: nowrap;
  }

  .map-link:hover {
    color: var(--color-accent-hover);
  }

  .map-link svg {
    width: 0.9rem;
    height: 0.9rem;
  }

  .sub-text {
    display: block;
    font-size: 0.8rem;
    opacity: 0.7;
    margin-top: 0.15rem;
  }

  .price-list {
    list-style: none;
  }

  .price-list li + li {
    margin-top: 0.15rem;
  }

  .event-actions {
    margin-top: 0.5rem;
  }

  .ticket-btn {
    display: inline-block;
    padding: 0.6rem 2rem;
    background: var(--color-red);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: var(--radius);
    transition:
      background 0.3s,
      transform 0.2s;
  }

  .ticket-btn:hover {
    background: var(--color-red-hover);
    color: #fff;
    transform: translateY(-1px);
  }

  .ticket-closed {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 480px) {
    .event-card {
      flex-direction: column;
      gap: 1rem;
    }

    .event-date-badge {
      flex-direction: row;
      gap: 0.5rem;
      min-width: auto;
      width: fit-content;
      padding: 0.3rem 0.8rem;
    }

    .detail-row {
      flex-direction: column;
      gap: 0.1rem;
    }

    .detail-row dt {
      min-width: auto;
      font-weight: 700;
      font-size: 0.78rem;
    }
  }
</style>
