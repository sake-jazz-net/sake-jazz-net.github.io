---
const channelUrl =
  "https://www.youtube.com/channel/UCoTBmnTZ5XwJY3Awkjjz_ag";

const videos = [
  {
    id: "LuItGeSY65I",
    title: "Live at HMVP Okachimachi Studio 3-27-2025 1st",
  },
  {
    id: "LO776Sahk2E",
    title: "Live at HMVP Okachimachi Studio 3-27-2025 2nd",
  },
  {
    id: "_cR5PDa9iTw",
    title: "Live at HMVP Okachimachi Studio 6-18-2025 2nd",
  },
];
---

<div class="yt-grid">
  {
    videos.map((v) => (
      <div class="yt-item">
        <div class="yt-wrapper">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${v.id}`}
            title={v.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
        <p class="yt-title">{v.title}</p>
      </div>
    ))
  }
</div>
<p class="yt-more">
  <a href={channelUrl} target="_blank" rel="noopener noreferrer">
    YouTubeチャンネルをもっと見る &rarr;
  </a>
</p>

<style>
  .yt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.2rem;
  }

  .yt-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .yt-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    background: #000;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .yt-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .yt-title {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .yt-more {
    margin-top: 1.5rem;
    text-align: center;
  }

  .yt-more a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .yt-more a:hover {
    color: var(--color-navy);
  }
</style>
