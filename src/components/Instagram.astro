---
const profileUrl =
  "https://www.instagram.com/happy_flight_jazz_orchestra/";
const handle = "@happy_flight_jazz_orchestra";

// Behold.so Feed ID — 取得後にここを更新
const feedId = "YOUR_FEED_ID";
---

{
  feedId !== "YOUR_FEED_ID" ? (
    <div class="ig-widget">
      <behold-widget feed-id={feedId} />
    </div>
  ) : (
    <div class="ig-fallback">
      <a
        href={profileUrl}
        class="ig-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          class="ig-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
        </svg>
        <span class="ig-handle">{handle}</span>
        <span class="ig-cta">Instagramを見る &rarr;</span>
      </a>
    </div>
  )
}

<p class="ig-more">
  <a href={profileUrl} target="_blank" rel="noopener noreferrer">
    Instagramでもっと見る &rarr;
  </a>
</p>

<script>
  const widget = document.querySelector("behold-widget");
  if (widget) {
    const s = document.createElement("script");
    s.type = "module";
    s.src = "https://w.behold.so/widget.js";
    document.head.appendChild(s);
  }
</script>

<style>
  .ig-widget {
    display: flex;
    justify-content: center;
  }

  .ig-fallback {
    display: flex;
    justify-content: center;
  }

  .ig-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding: 2rem 3rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    box-shadow: var(--shadow-sm);
    transition:
      border-color 0.3s,
      box-shadow 0.3s;
  }

  .ig-link:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
  }

  .ig-icon {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-red);
  }

  .ig-handle {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .ig-cta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .ig-more {
    margin-top: 1.2rem;
    text-align: center;
  }

  .ig-more a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .ig-more a:hover {
    color: var(--color-navy);
  }
</style>
