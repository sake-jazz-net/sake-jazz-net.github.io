---
const profileUrl =
  "https://www.instagram.com/happy_flight_jazz_orchestra/";
const handle = "@happy_flight_jazz_orchestra";
const embedUrl = `${profileUrl}embed/`;
---

<div class="ig-feed">
  <iframe
    src={embedUrl}
    class="ig-iframe"
    title={`${handle} Instagram Feed`}
    loading="lazy"
    allowtransparency="true"
    frameborder="0"
    scrolling="no"
  ></iframe>
</div>
<p class="ig-more">
  <a href={profileUrl} target="_blank" rel="noopener noreferrer">
    Instagramでもっと見る &rarr;
  </a>
</p>

<style>
  .ig-feed {
    display: flex;
    justify-content: center;
  }

  .ig-iframe {
    width: 100%;
    max-width: 540px;
    min-height: 600px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    box-shadow: var(--shadow-sm);
  }

  .ig-more {
    margin-top: 1.2rem;
    text-align: center;
  }

  .ig-more a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .ig-more a:hover {
    color: var(--color-navy);
  }
</style>
