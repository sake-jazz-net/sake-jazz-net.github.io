---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-links">
      <a href="/law">特定商取引法に基づく表記</a>
      <a href="/privacy">プライバシーポリシー</a>
    </div>
    <p class="footer-copy">&copy; {year} SAKE-JAZZ / 株式会社アーティストマージ</p>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    align-items: center;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .footer-copy {
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }
</style>
