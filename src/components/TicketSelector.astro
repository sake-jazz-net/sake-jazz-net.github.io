---
interface Ticket {
  label: string;
  amount: number;
  stripePriceId?: string;
  capacity?: number;
}

interface Props {
  tickets: Ticket[];
  eventTitle: string;
}

const { tickets, eventTitle } = Astro.props;
const stripePublishableKey =
  "pk_test_51TIgNPQ1qjm6yGpmoCOiDuplQj9jmVaRnCdH2kK9b2PW4Rzmz3ZOqdXJv1hJbJJUPpvacPIv4so7PHOFNFoo1ohC00GSZ7tGXe";
---

<div class="ticket-selector" data-stripe-pk={stripePublishableKey}>
  <h4 class="ticket-heading">チケットを選択</h4>
  <div class="ticket-list">
    {
      tickets.map((t, i) => (
        <label class="ticket-option">
          <input
            type="radio"
            name="ticket"
            value={t.stripePriceId || ""}
            data-label={t.label}
            data-amount={t.amount}
            checked={i === 0}
            disabled={!t.stripePriceId}
          />
          <span class="ticket-card">
            <span class="ticket-label">{t.label}</span>
            <span class="ticket-price">
              ¥{t.amount.toLocaleString("ja-JP")}
            </span>
            {t.capacity && (
              <span class="ticket-cap">定員 {t.capacity}名</span>
            )}
          </span>
        </label>
      ))
    }
  </div>
  <button class="checkout-btn" type="button">
    購入手続きへ
  </button>
  <p class="checkout-note">
    Stripe の安全な決済ページへ移動します（テストモード）
  </p>
</div>

<script>
  const container = document.querySelector(
    ".ticket-selector"
  ) as HTMLElement | null;
  if (container) {
    const pk = container.dataset.stripePk;
    const btn = container.querySelector(".checkout-btn") as HTMLButtonElement;

    btn.addEventListener("click", async () => {
      const selected = container.querySelector(
        'input[name="ticket"]:checked'
      ) as HTMLInputElement | null;
      if (!selected || !selected.value) return;

      btn.disabled = true;
      btn.textContent = "読み込み中...";

      const script = document.createElement("script");
      script.src = "https://js.stripe.com/v3/";
      script.onload = () => {
        // @ts-ignore
        const stripe = Stripe(pk);
        stripe.redirectToCheckout({
          lineItems: [{ price: selected.value, quantity: 1 }],
          mode: "payment",
          successUrl: `${window.location.origin}/checkout/success`,
          cancelUrl: `${window.location.origin}/checkout/cancel`,
        });
      };
      document.head.appendChild(script);
    });
  }
</script>

<style>
  .ticket-selector {
    margin-top: 1.5rem;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .ticket-heading {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 1rem;
  }

  .ticket-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
  }

  .ticket-option {
    cursor: pointer;
  }

  .ticket-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .ticket-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }

  .ticket-option input:checked + .ticket-card {
    border-color: var(--color-navy);
    box-shadow: 0 0 0 1px var(--color-navy);
  }

  .ticket-option input:focus-visible + .ticket-card {
    outline: 2px solid var(--color-navy);
    outline-offset: 2px;
  }

  .ticket-option:hover .ticket-card {
    border-color: var(--color-navy);
  }

  .ticket-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
    flex: 1;
  }

  .ticket-price {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-red);
    white-space: nowrap;
  }

  .ticket-cap {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .checkout-btn {
    display: block;
    width: 100%;
    padding: 0.8rem;
    background: var(--color-red);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition:
      background 0.3s,
      transform 0.2s;
  }

  .checkout-btn:hover {
    background: var(--color-red-hover);
    transform: translateY(-1px);
  }

  .checkout-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .checkout-note {
    margin-top: 0.6rem;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 480px) {
    .ticket-card {
      flex-wrap: wrap;
      gap: 0.3rem;
    }

    .ticket-cap {
      width: 100%;
    }
  }
</style>
