---
interface Ticket {
  label: string;
  amount: number;
  paymentUrl?: string;
  stripePriceId?: string;
  capacity?: number;
}

interface Props {
  tickets: Ticket[];
  eventTitle: string;
}

const { tickets, eventTitle } = Astro.props;
---

<div class="ticket-selector">
  <h4 class="ticket-heading">チケットを選択</h4>
  <div class="ticket-list">
    {
      tickets.map((t, i) => (
        <label class="ticket-option">
          <input
            type="radio"
            name="ticket"
            value={t.paymentUrl || ""}
            data-amount={t.amount}
            checked={i === 0}
            disabled={!t.paymentUrl}
          />
          <span class="ticket-card">
            <span class="ticket-label">{t.label}</span>
            <span class="ticket-price">
              ¥{t.amount.toLocaleString("ja-JP")}
            </span>
          </span>
        </label>
      ))
    }
  </div>

  <div class="qty-row">
    <span class="qty-label">枚数</span>
    <div class="qty-control">
      <button type="button" class="qty-btn qty-minus" aria-label="減らす">−</button>
      <span class="qty-value">1</span>
      <button type="button" class="qty-btn qty-plus" aria-label="増やす">＋</button>
    </div>
    <span class="qty-subtotal"></span>
  </div>

  <button class="checkout-btn" type="button">
    購入手続きへ
  </button>
  <p class="checkout-note">
    Stripe の安全な決済ページへ移動します（テストモード）
  </p>
</div>

<script>
  const container = document.querySelector(
    ".ticket-selector"
  ) as HTMLElement | null;

  if (container) {
    const btn = container.querySelector(".checkout-btn") as HTMLButtonElement;
    const qtyValue = container.querySelector(".qty-value") as HTMLSpanElement;
    const minusBtn = container.querySelector(".qty-minus") as HTMLButtonElement;
    const plusBtn = container.querySelector(".qty-plus") as HTMLButtonElement;
    const subtotal = container.querySelector(".qty-subtotal") as HTMLSpanElement;
    let qty = 1;

    function getSelectedAmount(): number {
      const sel = container!.querySelector(
        'input[name="ticket"]:checked'
      ) as HTMLInputElement | null;
      return sel ? Number(sel.dataset.amount) : 0;
    }

    function updateDisplay() {
      qtyValue.textContent = String(qty);
      minusBtn.disabled = qty <= 1;
      plusBtn.disabled = qty >= 10;
      const total = getSelectedAmount() * qty;
      subtotal.textContent = `合計 ¥${total.toLocaleString("ja-JP")}`;
    }

    minusBtn.addEventListener("click", () => {
      if (qty > 1) { qty--; updateDisplay(); }
    });

    plusBtn.addEventListener("click", () => {
      if (qty < 10) { qty++; updateDisplay(); }
    });

    container.querySelectorAll('input[name="ticket"]').forEach((radio) => {
      radio.addEventListener("change", updateDisplay);
    });

    updateDisplay();

    btn.addEventListener("click", () => {
      const selected = container!.querySelector(
        'input[name="ticket"]:checked'
      ) as HTMLInputElement | null;
      if (!selected || !selected.value) return;
      const url = new URL(selected.value);
      url.searchParams.set("quantity", String(qty));
      window.location.href = url.toString();
    });
  }
</script>

<style>
  .ticket-selector {
    margin-top: 1.5rem;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .ticket-heading {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 1rem;
  }

  .ticket-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
  }

  .ticket-option {
    cursor: pointer;
  }

  .ticket-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .ticket-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }

  .ticket-option input:checked + .ticket-card {
    border-color: var(--color-navy);
    box-shadow: 0 0 0 1px var(--color-navy);
  }

  .ticket-option input:focus-visible + .ticket-card {
    outline: 2px solid var(--color-navy);
    outline-offset: 2px;
  }

  .ticket-option:hover .ticket-card {
    border-color: var(--color-navy);
  }

  .ticket-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
    flex: 1;
  }

  .ticket-price {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-red);
    white-space: nowrap;
  }

  .qty-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .qty-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .qty-control {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .qty-btn {
    width: 2.2rem;
    height: 2.2rem;
    border: none;
    background: var(--color-bg-card);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .qty-btn:hover:not(:disabled) {
    background: var(--color-bg-card-hover);
  }

  .qty-btn:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .qty-value {
    width: 2.5rem;
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    background: var(--color-bg-card);
  }

  .qty-subtotal {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-red);
    margin-left: auto;
  }

  .checkout-btn {
    display: block;
    width: 100%;
    padding: 0.8rem;
    background: var(--color-red);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition:
      background 0.3s,
      transform 0.2s;
  }

  .checkout-btn:hover {
    background: var(--color-red-hover);
    transform: translateY(-1px);
  }

  .checkout-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .checkout-note {
    margin-top: 0.6rem;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.6;
  }

  @media (max-width: 480px) {
    .ticket-card {
      flex-wrap: wrap;
      gap: 0.3rem;
    }

    .qty-row {
      flex-wrap: wrap;
    }
  }
</style>
