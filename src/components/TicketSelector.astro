---
interface Ticket {
  label: string;
  amount: number;
  paymentUrl?: string;
  stripePriceId?: string;
  capacity?: number;
}

interface Props {
  tickets: Ticket[];
  eventTitle: string;
}

const { tickets, eventTitle } = Astro.props;
---

<div class="ticket-selector">
  <h4 class="ticket-heading">チケットを選択</h4>
  <div class="ticket-list">
    {
      tickets.map((t, i) => (
        <label class="ticket-option">
          <input
            type="radio"
            name="ticket"
            value={t.paymentUrl || ""}
            data-amount={t.amount}
            checked={i === 0}
            disabled={!t.paymentUrl}
          />
          <span class="ticket-card">
            <span class="ticket-label">{t.label}</span>
            <span class="ticket-price">
              ¥{t.amount.toLocaleString("ja-JP")}
            </span>
          </span>
        </label>
      ))
    }
  </div>

  <button class="checkout-btn" type="button">
    購入手続きへ
  </button>
  <p class="checkout-note">
    Stripe の決済ページへ移動します（テストモード）<br />
    複数枚購入する場合は、決済ページで枚数を変更できます
  </p>
</div>

<script>
  const container = document.querySelector(
    ".ticket-selector"
  ) as HTMLElement | null;

  if (container) {
    const btn = container.querySelector(".checkout-btn") as HTMLButtonElement;

    btn.addEventListener("click", () => {
      const selected = container.querySelector(
        'input[name="ticket"]:checked'
      ) as HTMLInputElement | null;
      if (!selected || !selected.value) return;
      window.location.href = selected.value;
    });
  }
</script>

<style>
  .ticket-selector {
    margin-top: 1.5rem;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .ticket-heading {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 1rem;
  }

  .ticket-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
  }

  .ticket-option {
    cursor: pointer;
  }

  .ticket-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .ticket-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }

  .ticket-option input:checked + .ticket-card {
    border-color: var(--color-navy);
    box-shadow: 0 0 0 1px var(--color-navy);
  }

  .ticket-option input:focus-visible + .ticket-card {
    outline: 2px solid var(--color-navy);
    outline-offset: 2px;
  }

  .ticket-option:hover .ticket-card {
    border-color: var(--color-navy);
  }

  .ticket-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
    flex: 1;
  }

  .ticket-price {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-red);
    white-space: nowrap;
  }

  .checkout-btn {
    display: block;
    width: 100%;
    padding: 0.8rem;
    background: var(--color-red);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition:
      background 0.3s,
      transform 0.2s;
  }

  .checkout-btn:hover {
    background: var(--color-red-hover);
    transform: translateY(-1px);
  }

  .checkout-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .checkout-note {
    margin-top: 0.6rem;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.6;
  }

  @media (max-width: 480px) {
    .ticket-card {
      flex-wrap: wrap;
      gap: 0.3rem;
    }
  }
</style>
