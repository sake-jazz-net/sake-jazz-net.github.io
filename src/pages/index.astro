---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import EventCard from "@/components/EventCard.astro";
import YouTube from "@/components/YouTube.astro";
import Instagram from "@/components/Instagram.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const allEvents = await getCollection("events", ({ data }) => !data.draft);
const sorted = allEvents.sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime()
);
const now = new Date();
const upcoming = sorted.filter((e) => e.data.date >= now);
const past = sorted.filter((e) => e.data.date < now).reverse();
---

<Base>
  <Header />
  {
    upcoming.map((event) => {
      const e = event.data;
      const jsonLd = {
        "@context": "https://schema.org",
        "@type": "MusicEvent",
        name: e.title,
        startDate: e.date.toISOString(),
        location: {
          "@type": "Place",
          name: e.location,
          address: e.address || e.location,
        },
        description: e.description || "",
        offers: (e.tickets || []).map((t: { label: string; amount: number; paymentUrl?: string }) => ({
          "@type": "Offer",
          name: t.label,
          price: t.amount,
          priceCurrency: "JPY",
          url: t.paymentUrl || "",
          availability: "https://schema.org/InStock",
        })),
        organizer: e.organizer
          ? { "@type": "Organization", name: e.organizer }
          : undefined,
      };
      return (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      );
    })
  }
  <main id="main-content">
    <Hero />

    <section id="events">
      <div class="container">
        <h2>Events</h2>

        {
          upcoming.length > 0 ? (
            <div class="event-list">
              {upcoming.map((event) => (
                <EventCard {...event.data} />
              ))}
            </div>
          ) : (
            <p class="no-events">зҸҫеңЁдәҲе®ҡгҒ•гӮҢгҒҰгҒ„гӮӢгӮӨгғҷгғігғҲгҒҜгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ</p>
          )
        }

        {
          past.length > 0 && (
            <details class="past-events">
              <summary>йҒҺеҺ»гҒ®гӮӨгғҷгғігғҲ</summary>
              <div class="event-list">
                {past.map((event) => (
                  <EventCard {...event.data} />
                ))}
              </div>
            </details>
          )
        }
      </div>
    </section>

    <section id="about">
      <div class="container">
        <h2>About</h2>
        <div class="about-layout">
          <div class="about-photo">
            <img
              src="/about.jpg"
              alt="Happy Flight Jazz Orchestra гғ©гӮӨгғ–жј”еҘҸйўЁжҷҜ"
              loading="lazy"
            />
          </div>
          <div class="about-body">
            <p>
              Happy Flight Jazz OrchestraгҒҜгҖҒжҜҺжңҲгҒ®гғ©гӮӨгғ–гӮӨгғҷгғігғҲгҒ§гғ“гғғгӮ°гғҗгғігғүгӮёгғЈгӮәгҒЁж—Ҙжң¬й…’гҒ®иһҚеҗҲгӮ’иҝҪжұӮгҒ—гҒҰгҒҚгҒҫгҒ—гҒҹгҖӮ
            </p>
            <p>
              гҒ“гҒ®жҙ»еӢ•гӮ’гҖҢSAKE-JAZZгҖҚгҒЁгҒ„гҒҶгғҶгғјгғһгҒ§гҒ•гӮүгҒ«зҷәеұ•гҒ•гҒӣгҖҒй…’и”өж§ҳгҒЁгҒ®гӮігғ©гғңгғ¬гғјгӮ·гғ§гғігӮӨгғҷгғігғҲгӮ’еұ•й–ӢгҒ—гҒҰгҒ„гҒҫгҒҷгҖӮ2017е№ҙгҒӢгӮүгӮ№гӮҝгғјгғҲгҒ—гҒҹгҖҢиұҠеі¶еұӢгӮёгғЈгӮәгҖҚгҒ§гҒҜгҖҒй…’и”өгҒ®йӣ°еӣІж°—гҒЁйҹіжҘҪгҒҢиӘҝе’ҢгҒ—гҖҒжҜҺеӣһеӨ§еҘҪи©•гӮ’гҒ„гҒҹгҒ гҒ„гҒҰгҒ„гҒҫгҒҷгҖӮ
            </p>
            <p>
              гӮҲгӮҠеӨҡгҒҸгҒ®ж–№гҖ…гҒ«ж—Ҙжң¬й…’гҒ®йӯ…еҠӣгҒЁгӮёгғЈгӮәгҒ®жҘҪгҒ—гҒ•гӮ’е…ұжңүгҒ—гҒҰгҒ„гҒҹгҒ гҒ‘гӮӢгҒ“гҒЁгӮ’жҘҪгҒ—гҒҝгҒ«гҒ—гҒҰгҒҠгӮҠгҒҫгҒҷгҖӮ
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="instagram">
      <div class="container">
        <h2>Instagram</h2>
        <Instagram />
      </div>
    </section>

    <section id="youtube">
      <div class="container">
        <h2>YouTube</h2>
        <YouTube />
      </div>
    </section>

    <section id="contact">
      <div class="container">
        <h2>Contact</h2>
        <div class="contact-body">
          <p>гӮӨгғҷгғігғҲгҒ«й–ўгҒҷгӮӢгҒҠе•ҸгҒ„еҗҲгӮҸгҒӣгҒҜгғЎгғјгғ«гҒ«гҒҰгҒҠйЎҳгҒ„гҒ„гҒҹгҒ—гҒҫгҒҷгҖӮ</p>
          <a href="mailto:info.happyflight2@gmail.com" class="contact-email">
            info.happyflight2@gmail.com
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .event-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .no-events {
    text-align: center;
    color: var(--color-text-muted);
    padding: 3rem 0;
    font-style: italic;
  }

  .past-events {
    margin-top: 2.5rem;
  }

  .past-events summary {
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
    user-select: none;
  }

  .past-events summary:hover {
    color: var(--color-accent);
  }

  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .about-photo img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
  }

  .about-body p {
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    line-height: 1.9;
  }

  @media (max-width: 640px) {
    .about-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .contact-body {
    max-width: 640px;
  }

  .contact-body p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .contact-email {
    display: inline-block;
    padding: 0.6rem 2rem;
    border: 1px solid var(--color-navy);
    border-radius: var(--radius);
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    color: var(--color-navy);
  }

  .contact-email:hover {
    background: var(--color-navy);
    color: #fff;
  }
</style>
